events {}

http {
    server {
        listen 80;
        server_name ${DOMAIN} www.${DOMAIN};

        location / {
            proxy_pass http://frontend:80;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        location /api/ {
            proxy_pass http://backend:8080/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        location ~ ^/(swagger|v1)/ {
            rewrite ^/(.*)$ /api/$1 last;
        }
    }
}